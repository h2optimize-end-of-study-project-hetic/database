# POSTGRES
POSTGRES_HOST=postgres
POSTGRES_VERSION=0.0.1
POSTGRES_IMAGE=postgres:v0.0.1
GHCR_LOCATION=h2optimize-end-of-study-project-hetic
POSTGRES_EXT_PORT=5432
POSTGRES_INT_PORT=5432 # Pour telegraf
POSTGRES_DB=app
POSTGRES_USER=admin
POSTGRES_PASSWORD=Changeme!1
POSTGRES_NETWORK_NAME=postgres_net
POSTGRES_VOLUME_NAME=postgres_data
POSTGRES_DB_RECORDED=recorded


# PGADMIN
PGADMIN_HOST=pgadmin
PGADMIN_EXT_PORT=8080
PGADMIN_DEFAULT_EMAIL=admin@admin.fr
PGADMIN_DEFAULT_PASSWORD=Changeme!1

# !!! IMPORTANT !!! 
# In production set: 
#
# PGADMIN_CONFIG_SERVER_MODE=True
#
PGADMIN_CONFIG_SERVER_MODE=False
